## ---- 8. 多方法 + 多次 replicate 的 meta 仿真 ----
## 功能：
##   对多个 reconstruction 方法 (methods)，在同一套真参数下，
##   重复 n_rep 次：
##     - 调 simulate_meta_one_rep_recon()
##     - 得到 meta_true 与 meta_recon
##   并对每个方法输出：
##     - 相对于真值 mu_logHR 的 bias / RMSE（true & recon）
##     - recon 相对于 true 的增量误差 (delta)
##
## 依赖：
##   - simulate_meta_one_rep_recon()
##   - reconstruct_fun_ipdfromkm()
##   - reconstruct_fun_kmdata_guyot()
##   - reconstruct_fun_kmtoipd_rogula()


simulate_meta_replicate_multi_methods <- function(
    n_rep,
    methods = c("ipdfromkm", "kmdata_guyot", "kmtoipd_rogula"),
    K,
    dist = c("weibull"),
    baseline_params,
    mu_logHR,
    tau2_logHR,
    n_control,
    n_treatment,
    target_censoring = 0.25,
    accrual = 0,
    meta_method = "REML",
    sd_S = 0.01,      # digitize 噪声
    seed = NULL       # 总体种子（用来构造每个 replicate 的子 seed）
) {
  dist <- match.arg(dist)
  methods <- as.character(methods)
  n_m <- length(methods)

  if (!is.null(seed)) set.seed(seed)
  stopifnot(n_rep >= 1L, n_m >= 1L)

  HR_true_val   <- exp(mu_logHR)   # 理论真 HR
  tau2_true_val <- tau2_logHR      # 理论真 tau²（logHR 空间的方差）

  ## --- 1. 准备存放各方法 x 各 replicate 的 meta 结果矩阵 ---

  # true meta
  logHR_true_mat    <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  HR_true_mat       <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  tau2_true_mat     <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  I2_true_mat       <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  ciL_true_mat      <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  ciU_true_mat      <- matrix(NA_real_, nrow = n_m, ncol = n_rep)

  # recon meta
  logHR_recon_mat   <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  HR_recon_mat      <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  tau2_recon_mat    <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  I2_recon_mat      <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  ciL_recon_mat     <- matrix(NA_real_, nrow = n_m, ncol = n_rep)
  ciU_recon_mat     <- matrix(NA_real_, nrow = n_m, ncol = n_rep)

  rownames(logHR_true_mat)  <- methods
  rownames(HR_true_mat)     <- methods
  rownames(tau2_true_mat)   <- methods
  rownames(I2_true_mat)     <- methods
  rownames(ciL_true_mat)    <- methods
  rownames(ciU_true_mat)    <- methods

  rownames(logHR_recon_mat) <- methods
  rownames(HR_recon_mat)    <- methods
  rownames(tau2_recon_mat)  <- methods
  rownames(I2_recon_mat)    <- methods
  rownames(ciL_recon_mat)   <- methods
  rownames(ciU_recon_mat)   <- methods

  ## --- 2. 一个小工具：method -> 对应的 reconstruct_fun wrapper ---

  get_reconstruct_fun <- function(method) {
    switch(
      method,
      "ipdfromkm"      = reconstruct_fun_ipdfromkm,
      "kmdata_guyot"   = reconstruct_fun_kmdata_guyot,
      "kmtoipd_rogula" = reconstruct_fun_kmtoipd_rogula,
      stop("Unknown method: ", method)
    )
  }

  ## --- 3. 大循环：replicate x method ----------------------------

  for (r in seq_len(n_rep)) {
    # 为这一轮构造一个子 seed（如果总 seed 为空，就让内部自己跑）
    seed_r <- if (!is.null(seed)) seed + r - 1L else NULL

    for (m_idx in seq_len(n_m)) {
      method <- methods[m_idx]
      reconstruct_fun_m <- get_reconstruct_fun(method)

      # 每个方法在这一 replicate 上用同一个 seed_r
      res_rm <- simulate_meta_one_rep_recon(
        K               = K,
        dist            = dist,
        baseline_params = baseline_params,
        mu_logHR        = mu_logHR,
        tau2_logHR      = tau2_logHR,
        n_control       = n_control,
        n_treatment     = n_treatment,
        target_censoring = target_censoring,
        accrual         = accrual,
        reconstruct_fun = function(ipd_true, trial_id, ...) {
          reconstruct_fun_m(ipd_true, trial_id, sd_S = sd_S, ...)
        },
        meta_method     = meta_method,
        seed            = seed_r
      )

      # 可能出现 NA（例如某次模拟里 <2 个有效 trial），这里统一兼容
      # true meta
      logHR_true_mat[m_idx, r] <- res_rm$meta_true$logHR_meta
      HR_true_mat[m_idx, r]    <- res_rm$meta_true$HR_meta
      tau2_true_mat[m_idx, r]  <- res_rm$meta_true$tau2
      I2_true_mat[m_idx, r]    <- res_rm$meta_true$I2
      ciL_true_mat[m_idx, r]   <- res_rm$meta_true$ci_lower
      ciU_true_mat[m_idx, r]   <- res_rm$meta_true$ci_upper

      # recon meta
      logHR_recon_mat[m_idx, r] <- res_rm$meta_recon$logHR_meta
      HR_recon_mat[m_idx, r]    <- res_rm$meta_recon$HR_meta
      tau2_recon_mat[m_idx, r]  <- res_rm$meta_recon$tau2
      I2_recon_mat[m_idx, r]    <- res_rm$meta_recon$I2
      ciL_recon_mat[m_idx, r]   <- res_rm$meta_recon$ci_lower
      ciU_recon_mat[m_idx, r]   <- res_rm$meta_recon$ci_upper
    }
  }

  ## --- 4. 按方法汇总 summary -----------------------------------

  summary_list <- vector("list", length = n_m)
  names(summary_list) <- methods

  for (m_idx in seq_len(n_m)) {
    method <- methods[m_idx]

    # 有效 replicate：true 和 recon 都非 NA
    valid_idx <- which(
      is.finite(HR_true_mat[m_idx, ])   &
        is.finite(HR_recon_mat[m_idx, ])  &
        is.finite(logHR_true_mat[m_idx, ]) &
        is.finite(logHR_recon_mat[m_idx, ])
    )

    if (length(valid_idx) == 0L) {
      warning("Method ", method, ": all replicates NA; summary set to NA.")
      summary_list[[method]] <- list(
        method            = method,
        n_valid           = 0L,
        # HR 层面
        mean_HR_true      = NA_real_,
        bias_HR_true      = NA_real_,
        rmse_HR_true      = NA_real_,
        mean_HR_recon     = NA_real_,
        bias_HR_recon     = NA_real_,
        rmse_HR_recon     = NA_real_,
        mean_delta_HR     = NA_real_,
        rmse_delta_HR     = NA_real_,
        # tau2
        mean_tau2_true    = NA_real_,
        mean_tau2_recon   = NA_real_,
        bias_tau2_true    = NA_real_,
        rmse_tau2_true    = NA_real_,
        bias_tau2_recon   = NA_real_,
        rmse_tau2_recon   = NA_real_,
        # I2
        mean_I2_true      = NA_real_,
        mean_I2_recon     = NA_real_,
        # coverage
        coverage_true     = NA_real_,
        coverage_recon    = NA_real_
      )
      next
    }

    # 取子向量
    HR_true_vec     <- HR_true_mat[m_idx, valid_idx]
    HR_recon_vec    <- HR_recon_mat[m_idx, valid_idx]
    logHR_true_vec  <- logHR_true_mat[m_idx, valid_idx]
    logHR_recon_vec <- logHR_recon_mat[m_idx, valid_idx]
    tau2_true_vec   <- tau2_true_mat[m_idx, valid_idx]
    tau2_recon_vec  <- tau2_recon_mat[m_idx, valid_idx]
    I2_true_vec     <- I2_true_mat[m_idx, valid_idx]
    I2_recon_vec    <- I2_recon_mat[m_idx, valid_idx]
    ciL_true_vec    <- ciL_true_mat[m_idx, valid_idx]
    ciU_true_vec    <- ciU_true_mat[m_idx, valid_idx]
    ciL_recon_vec   <- ciL_recon_mat[m_idx, valid_idx]
    ciU_recon_vec   <- ciU_recon_mat[m_idx, valid_idx]

    ## HR vs 理论真 HR
    mean_HR_true <- mean(HR_true_vec)
    bias_HR_true <- mean(HR_true_vec - HR_true_val)
    rmse_HR_true <- sqrt(mean((HR_true_vec - HR_true_val)^2))

    mean_HR_recon <- mean(HR_recon_vec)
    bias_HR_recon <- mean(HR_recon_vec - HR_true_val)
    rmse_HR_recon <- sqrt(mean((HR_recon_vec - HR_true_val)^2))

    ## recon vs true 的增量误差
    delta_HR   <- HR_recon_vec - HR_true_vec
    mean_delta <- mean(delta_HR)
    rmse_delta <- sqrt(mean(delta_HR^2))

    ## tau2: 均值 + 相对于理论值的 bias / RMSE
    mean_tau2_true  <- mean(tau2_true_vec,  na.rm = TRUE)
    mean_tau2_recon <- mean(tau2_recon_vec, na.rm = TRUE)

    bias_tau2_true  <- mean(tau2_true_vec  - tau2_true_val, na.rm = TRUE)
    rmse_tau2_true  <- sqrt(mean((tau2_true_vec  - tau2_true_val)^2, na.rm = TRUE))
    bias_tau2_recon <- mean(tau2_recon_vec - tau2_true_val, na.rm = TRUE)
    rmse_tau2_recon <- sqrt(mean((tau2_recon_vec - tau2_true_val)^2, na.rm = TRUE))

    ## I2 平均值
    mean_I2_true  <- mean(I2_true_vec,  na.rm = TRUE)
    mean_I2_recon <- mean(I2_recon_vec, na.rm = TRUE)

    ## 95% CI 覆盖真 HR 的比例 (coverage)
    cover_true  <- mean(ciL_true_vec  <= HR_true_val & ciU_true_vec  >= HR_true_val, na.rm = TRUE)
    cover_recon <- mean(ciL_recon_vec <= HR_true_val & ciU_recon_vec >= HR_true_val, na.rm = TRUE)

    summary_list[[method]] <- list(
      method            = method,
      n_valid           = length(valid_idx),
      mean_HR_true      = mean_HR_true,
      bias_HR_true      = bias_HR_true,
      rmse_HR_true      = rmse_HR_true,
      mean_HR_recon     = mean_HR_recon,
      bias_HR_recon     = bias_HR_recon,
      rmse_HR_recon     = rmse_HR_recon,
      mean_delta_HR     = mean_delta,
      rmse_delta_HR     = rmse_delta,
      mean_tau2_true    = mean_tau2_true,
      mean_tau2_recon   = mean_tau2_recon,
      bias_tau2_true    = bias_tau2_true,
      rmse_tau2_true    = rmse_tau2_true,
      bias_tau2_recon   = bias_tau2_recon,
      rmse_tau2_recon   = rmse_tau2_recon,
      mean_I2_true      = mean_I2_true,
      mean_I2_recon     = mean_I2_recon,
      coverage_true     = cover_true,
      coverage_recon    = cover_recon
    )
  }

  ## --- 5. 打包输出 ---------------------------------------------

  list(
    settings = list(
      n_rep           = n_rep,
      methods         = methods,
      K               = K,
      dist            = dist,
      baseline_params = baseline_params,
      mu_logHR        = mu_logHR,
      tau2_logHR      = tau2_logHR,
      HR_true         = HR_true_val,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual,
      meta_method     = meta_method,
      sd_S            = sd_S,
      seed            = seed
    ),
    raw = list(
      logHR_true   = logHR_true_mat,
      HR_true      = HR_true_mat,
      tau2_true    = tau2_true_mat,
      I2_true      = I2_true_mat,
      ciL_true     = ciL_true_mat,
      ciU_true     = ciU_true_mat,
      logHR_recon  = logHR_recon_mat,
      HR_recon     = HR_recon_mat,
      tau2_recon   = tau2_recon_mat,
      I2_recon     = I2_recon_mat,
      ciL_recon    = ciL_recon_mat,
      ciU_recon    = ciU_recon_mat
    ),
    summary = summary_list
  )
}

