## ---- 10. scenario grid ----
make_meta_scenario_grid_paper <- function(
    mu_HR        = 0.75,
    baseline_shape = 1.2,
    baseline_scale = 10
) {
  # 1) 先定义“小 / 大 meta”的 (K, n) 结构
  size_dt <- data.table(
    size_label = c("small", "large"),
    K          = c(5L, 15L),
    n_control  = c(80L, 200L),
    n_treatment = c(80L, 200L)
  )

  # 2) 其他维度：tau2, censoring, sd_S
  tau2_vec   <- c(0, 0.02, 0.08)
  censor_vec <- c(0.20, 0.50)
  sd_S_vec   <- c(0.00, 0.02)
  accrual_vec <- 0  # 先固定不分期入组，有需要再扩展

  other_dt <- CJ(
    tau2_logHR      = tau2_vec,
    target_censoring = censor_vec,
    sd_S            = sd_S_vec,
    accrual         = accrual_vec
  )

  # 3) 做笛卡尔积：size_dt × other_dt
  scen <- size_dt[, .(size_label, K, n_control, n_treatment)][
    , cbind(.SD, other_dt), by = .(size_label, K, n_control, n_treatment)
  ]

  # 4) 固定 baseline 和真 HR/logHR
  scen[, baseline_shape := baseline_shape]
  scen[, baseline_scale := baseline_scale]
  scen[, mu_HR         := mu_HR]
  scen[, mu_logHR      := log(mu_HR)]

  # 5) 给每行一个 scenario_id 方便引用
  scen[, scenario_id := .I]

  # 排个序（可选）
  setcolorder(scen, c(
    "scenario_id",
    "size_label",
    "K", "n_control", "n_treatment",
    "baseline_shape", "baseline_scale",
    "mu_HR", "mu_logHR",
    "tau2_logHR",
    "target_censoring",
    "sd_S",
    "accrual"
  ))

  scen[]
}


run_meta_paper_benchmark <- function(
    n_rep_per_scenario = 500,
    methods    = c("ipdfromkm", "kmdata_guyot", "kmtoipd_rogula"),
    meta_method = "REML",
    mu_HR       = 0.75,
    baseline_shape = 1.2,
    baseline_scale = 10,
    seed_base   = 2026,
    out_file    = "meta_benchmark_results_paper.csv",
    verbose     = TRUE
) {
  # 1) 生成论文级 scenario grid
  scen_grid <- make_meta_scenario_grid_paper(
    mu_HR         = mu_HR,
    baseline_shape = baseline_shape,
    baseline_scale = baseline_scale
  )

  if (verbose) {
    message("Total scenarios to run: ", nrow(scen_grid))
    print(scen_grid)
  }

  # 2) 跑全部 scenario × methods
  res_batch <- run_meta_scenarios_batch(
    scenario_grid = scen_grid,
    n_rep         = n_rep_per_scenario,
    methods       = methods,
    meta_method   = meta_method,
    seed_base     = seed_base,
    verbose       = verbose
  )

  # 3) 导出 CSV
  data.table::fwrite(res_batch, file = out_file)

  if (verbose) {
    message("Benchmark finished. Results saved to: ", normalizePath(out_file, winslash = "/"))
  }

  # 4) 返回对象，方便你在 R 里继续分析或画图
  list(
    scenario_grid = scen_grid,
    results       = res_batch
  )
}

