## ---- 6. Single meta replicate with reconstruction ----
## 在 simulate_meta_one_rep 的基础上增加:
##   - reconstruct_fun(ipd_true, trial_id, ...) 生成每个 trial 的重建 IPD
##   - trial-level 和 meta-level 同时输出 true / recon 两套结果


simulate_meta_one_rep_recon <- function(
    K,
    dist = c("weibull"),
    baseline_params,
    mu_logHR,
    tau2_logHR,
    n_control,
    n_treatment,
    target_censoring = 0.25,
    accrual = 0,
    reconstruct_fun,
    meta_method = "REML",
    seed = NULL,
    ...
) {
  dist <- match.arg(dist)

  if (!is.null(seed)) set.seed(seed)

  stopifnot(K >= 1L)
  stopifnot(n_control > 0, n_treatment > 0)
  stopifnot(target_censoring >= 0, target_censoring <= 0.95)
  stopifnot(baseline_params$shape > 0, baseline_params$scale > 0)
  stopifnot(tau2_logHR >= 0)

  shape      <- baseline_params$shape
  scale_ctrl <- baseline_params$scale

  # 容器：true parameters
  logHR_true <- numeric(K)
  HR_true    <- numeric(K)

  # trial-level estimates (true IPD)
  logHR_hat_true <- numeric(K)
  HR_hat_true    <- numeric(K)
  se_logHR_true  <- numeric(K)

  # trial-level estimates (reconstructed IPD)
  logHR_hat_recon <- numeric(K)
  HR_hat_recon    <- numeric(K)
  se_logHR_recon  <- numeric(K)

  for (j in seq_len(K)) {
    ## --- 1) 抽第 j 个 trial 的真 log(HR_j) ---
    logHR_j <- stats::rnorm(1, mean = mu_logHR, sd = sqrt(tau2_logHR))
    HR_j    <- exp(logHR_j)

    logHR_true[j] <- logHR_j
    HR_true[j]    <- HR_j

    ## --- 2) 构造 treatment 组 Weibull 参数 ---
    # HR = (scale_ctrl / scale_trt)^shape => scale_trt = scale_ctrl * HR^(-1/shape)
    scale_trt <- scale_ctrl * HR_j^(-1 / shape)

    control_params <- list(shape = shape, scale = scale_ctrl)
    treat_params   <- list(shape = shape, scale = scale_trt)

    ## --- 3) 模拟 true IPD for trial j ---
    ipd_true_j <- simulate_trial_twoarm_param(
      trial_id        = j,
      dist            = dist,
      control_params  = control_params,
      treat_params    = treat_params,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual
    )

    ## --- 4) 用 true IPD 估计 HR ---
    est_true_j <- estimate_trial_hr(ipd_true_j)

    logHR_hat_true[j] <- est_true_j$logHR_hat
    HR_hat_true[j]    <- est_true_j$HR_hat
    se_logHR_true[j]  <- est_true_j$se_logHR

    ## --- 5) 调用 reconstruct_fun 得到重建 IPD ---
    ipd_recon_j <- reconstruct_fun(ipd_true_j, trial_id = j, ...)

    # 确保基本列存在
    ipd_recon_j <- as.data.frame(ipd_recon_j)
    if (!all(c("arm", "time", "status") %in% names(ipd_recon_j))) {
      warning("Reconstructed IPD for trial ", j,
              " lacks required columns; set HR_recon = NA.")
      logHR_hat_recon[j] <- NA_real_
      HR_hat_recon[j]    <- NA_real_
      se_logHR_recon[j]  <- NA_real_
      next
    }

    # 确保 arm 是 0/1
    if (is.character(ipd_recon_j$arm) || is.factor(ipd_recon_j$arm)) {
      ipd_recon_j$arm <- ifelse(ipd_recon_j$arm == "Treatment", 1L, 0L)
    } else {
      ipd_recon_j$arm <- as.integer(ipd_recon_j$arm)
    }

    # 加一列 trial_id（以防 reconstruct_fun 没加）
    if (!"trial_id" %in% names(ipd_recon_j)) {
      ipd_recon_j$trial_id <- j
    }

    ## --- 6) 用重建 IPD 估计 HR ---
    est_recon_j <- estimate_trial_hr(ipd_recon_j)

    logHR_hat_recon[j] <- est_recon_j$logHR_hat
    HR_hat_recon[j]    <- est_recon_j$HR_hat
    se_logHR_recon[j]  <- est_recon_j$se_logHR
  }

  ## --- 7) meta 分析：true vs recon ---
  meta_true <- meta_analyze_two_stage(
    logHR_vec = logHR_hat_true,
    se_vec    = se_logHR_true,
    method    = meta_method
  )

  meta_recon <- meta_analyze_two_stage(
    logHR_vec = logHR_hat_recon,
    se_vec    = se_logHR_recon,
    method    = meta_method
  )

  list(
    settings = list(
      K               = K,
      dist            = dist,
      baseline_params = baseline_params,
      mu_logHR        = mu_logHR,
      tau2_logHR      = tau2_logHR,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual,
      meta_method     = meta_method
    ),
    trial_level = list(
      logHR_true      = logHR_true,
      HR_true         = HR_true,
      logHR_hat_true  = logHR_hat_true,
      HR_hat_true     = HR_hat_true,
      se_logHR_true   = se_logHR_true,
      logHR_hat_recon = logHR_hat_recon,
      HR_hat_recon    = HR_hat_recon,
      se_logHR_recon  = se_logHR_recon
    ),
    meta_true  = meta_true,
    meta_recon = meta_recon
  )
}

