## ---- 4. Meta-analysis simulation: one replicate (K trials) ----


simulate_meta_one_rep <- function(
    K,
    dist = c("weibull"),
    baseline_params,            # list(shape, scale) for Control
    mu_logHR,
    tau2_logHR,
    n_control,
    n_treatment,
    target_censoring = 0.25,
    accrual = 0,
    meta_method = "REML",
    seed = NULL
) {
  dist <- match.arg(dist)

  if (!is.null(seed)) set.seed(seed)

  # 检查输入
  stopifnot(K >= 1L)
  stopifnot(n_control > 0, n_treatment > 0)
  stopifnot(target_censoring >= 0, target_censoring <= 0.95)
  stopifnot(baseline_params$shape > 0, baseline_params$scale > 0)
  stopifnot(tau2_logHR >= 0)

  shape      <- baseline_params$shape
  scale_ctrl <- baseline_params$scale

  # 容器：trial-level 真值 + 估计值
  logHR_true <- numeric(K)
  HR_true    <- numeric(K)
  logHR_hat  <- numeric(K)
  HR_hat     <- numeric(K)
  se_logHR   <- numeric(K)

  for (j in seq_len(K)) {
    # 1) 抽第 j 个 trial 的真 log(HR_j)
    logHR_j <- stats::rnorm(1, mean = mu_logHR, sd = sqrt(tau2_logHR))
    HR_j    <- exp(logHR_j)

    logHR_true[j] <- logHR_j
    HR_true[j]    <- HR_j

    # 2) 根据 HR_j 构造 treatment Weibull 参数
    #    HR = (scale_ctrl / scale_trt)^shape  => scale_trt = scale_ctrl * HR^(-1/shape)
    scale_trt <- scale_ctrl * HR_j^(-1 / shape)

    control_params <- list(shape = shape, scale = scale_ctrl)
    treat_params   <- list(shape = shape, scale = scale_trt)

    # 3) 模拟第 j 个 trial 的真 IPD
    ipd_j <- simulate_trial_twoarm_param(
      trial_id        = j,
      dist            = dist,
      control_params  = control_params,
      treat_params    = treat_params,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual
      # seed 不再每个 trial 单独设 seed，统一由总 seed 控制
    )

    # 4) 用 Cox 估计 HR
    est_j <- estimate_trial_hr(ipd_j)

    logHR_hat[j] <- est_j$logHR_hat
    HR_hat[j]    <- est_j$HR_hat
    se_logHR[j]  <- est_j$se_logHR
  }

  # 5) Two-stage meta-analysis on estimated HRs
  meta_res <- meta_analyze_two_stage(
    logHR_vec = logHR_hat,
    se_vec    = se_logHR,
    method    = meta_method
  )

  list(
    settings = list(
      K               = K,
      dist            = dist,
      baseline_params = baseline_params,
      mu_logHR        = mu_logHR,
      tau2_logHR      = tau2_logHR,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual,
      meta_method     = meta_method
    ),
    trial_level = list(
      logHR_true = logHR_true,
      HR_true    = HR_true,
      logHR_hat  = logHR_hat,
      HR_hat     = HR_hat,
      se_logHR   = se_logHR
    ),
    meta = meta_res
  )
}

