## Phase 3: scenario grid with missing HR + rare disease
make_meta_scenario_grid_phase3 <- function(
    mu_HR          = 0.75,
    baseline_shape = 1.2,
    baseline_scale = 10
) {
  stopifnot(requireNamespace("data.table", quietly = TRUE))
  library(data.table)

  mu_logHR <- log(mu_HR)

  ## ---------- Block A: baseline, no missing HR ----------
  blockA <- CJ(
    block            = "A_baseline_no_missing",
    K                = c(5L, 15L),
    tau2_logHR       = c(0, 0.05),
    target_censoring = c(0.2, 0.5),
    sd_S             = c(0, 0.02)
  )
  blockA[, `:=`(
    n_control   = 200L,
    n_treatment = 200L,
    p_miss_HR   = 0,
    accrual     = 0,
    size_label  = "baseline"
  )]

  ## ---------- Block B: standard setting + missing HR ----------
  blockB <- CJ(
    block      = "B_missingHR_standard",
    K          = c(5L, 15L),
    p_miss_HR  = c(0.3, 0.6)
  )
  blockB[, `:=`(
    tau2_logHR       = 0.05,
    target_censoring = 0.2,
    sd_S             = 0.02,
    n_control        = 200L,
    n_treatment      = 200L,
    accrual          = 0,
    size_label       = "standard"
  )]

  ## ---------- Block C: strong heterogeneity + missing HR ----------
  blockC <- CJ(
    block            = "C_strong_heterogeneity",
    target_censoring = c(0.2, 0.5),
    p_miss_HR        = c(0.3, 0.6)
  )
  blockC[, `:=`(
    K            = 10L,
    tau2_logHR   = 0.10,
    sd_S         = 0.02,
    n_control    = 200L,
    n_treatment  = 200L,
    accrual      = 0,
    size_label   = "strong_hetero"
  )]

  ## ---------- Block D: rare disease (many small sites) ----------
  blockD <- CJ(
    block      = "D_rare_disease",
    K          = c(20L, 40L),
    tau2_logHR = c(0.02, 0.05),
    p_miss_HR  = c(0.3, 0.6)
  )
  blockD[, `:=`(
    target_censoring = 0.5,
    sd_S             = 0.02,
    n_control        = 40L,
    n_treatment      = 40L,
    accrual          = 0,
    size_label       = "rare_disease"
  )]

  ## ---------- bind & add common columns ----------
  scen <- rbindlist(list(blockA, blockB, blockC, blockD), use.names = TRUE, fill = TRUE)

  scen[, `:=`(
    baseline_shape = baseline_shape,
    baseline_scale = baseline_scale,
    mu_HR          = mu_HR,
    mu_logHR       = mu_logHR,
    tau2_logHR_true = tau2_logHR
  )]

  scen[, scenario_id := .I]

  # 列顺序稍微整理一下
  setcolorder(
    scen,
    c("scenario_id", "block", "size_label",
      "K", "n_control", "n_treatment",
      "baseline_shape", "baseline_scale",
      "mu_HR", "mu_logHR", "tau2_logHR_true",
      "target_censoring", "accrual",
      "sd_S", "p_miss_HR")
  )

  scen[]
}
