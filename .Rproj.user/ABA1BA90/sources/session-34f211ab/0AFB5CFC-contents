## ---- 5. Multiple replicates: summarize bias / RMSE ----

simulate_meta_replicate <- function(
    n_rep,
    K,
    dist = c("weibull"),
    baseline_params,
    mu_logHR,
    tau2_logHR,
    n_control,
    n_treatment,
    target_censoring = 0.25,
    accrual = 0,
    meta_method = "REML",
    seed = NULL
) {
  dist <- match.arg(dist)

  if (!is.null(seed)) set.seed(seed)

  stopifnot(n_rep >= 1L)

  # 容器：每次 replicate 的 meta-level 结果
  logHR_meta_vec <- numeric(n_rep)
  HR_meta_vec    <- numeric(n_rep)
  tau2_meta_vec  <- numeric(n_rep)
  I2_meta_vec    <- numeric(n_rep)

  for (r in seq_len(n_rep)) {
    res_r <- simulate_meta_one_rep(
      K               = K,
      dist            = dist,
      baseline_params = baseline_params,
      mu_logHR        = mu_logHR,
      tau2_logHR      = tau2_logHR,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual,
      meta_method     = meta_method,
      seed            = NULL  # 每个 replicate 内部再用随机数，不单独设 seed
    )

    logHR_meta_vec[r] <- res_r$meta$logHR_meta
    HR_meta_vec[r]    <- res_r$meta$HR_meta
    tau2_meta_vec[r]  <- res_r$meta$tau2
    I2_meta_vec[r]    <- res_r$meta$I2
  }

  # 去掉可能的 NA（极端情况下某些 replicate 会因为没有有效 trial 而 NA）
  valid_idx <- which(is.finite(logHR_meta_vec) &
                       is.finite(HR_meta_vec) &
                       is.finite(tau2_meta_vec) &
                       is.finite(I2_meta_vec))

  if (length(valid_idx) == 0L) {
    warning("All replicates produced NA meta results; returning NA summary.")
    return(list(
      settings = list(
        n_rep           = n_rep,
        K               = K,
        dist            = dist,
        baseline_params = baseline_params,
        mu_logHR        = mu_logHR,
        tau2_logHR      = tau2_logHR,
        n_control       = n_control,
        n_treatment     = n_treatment,
        target_censoring = target_censoring,
        accrual         = accrual,
        meta_method     = meta_method
      ),
      meta_paths = list(
        logHR_meta = logHR_meta_vec,
        HR_meta    = HR_meta_vec,
        tau2_meta  = tau2_meta_vec,
        I2_meta    = I2_meta_vec
      ),
      summary = list(
        mean_logHR_meta = NA_real_,
        bias_logHR      = NA_real_,
        rmse_logHR      = NA_real_,
        mean_HR_meta    = NA_real_,
        bias_HR         = NA_real_,
        rmse_HR         = NA_real_,
        mean_tau2       = NA_real_,
        bias_tau2       = NA_real_,
        rmse_tau2       = NA_real_,
        mean_I2         = NA_real_
      )
    ))
  }

  logHR_meta_use <- logHR_meta_vec[valid_idx]
  HR_meta_use    <- HR_meta_vec[valid_idx]
  tau2_meta_use  <- tau2_meta_vec[valid_idx]
  I2_meta_use    <- I2_meta_vec[valid_idx]

  HR_true <- exp(mu_logHR)

  summary_list <- list(
    mean_logHR_meta = mean(logHR_meta_use),
    bias_logHR      = mean(logHR_meta_use - mu_logHR),
    rmse_logHR      = sqrt(mean((logHR_meta_use - mu_logHR)^2)),
    mean_HR_meta    = mean(HR_meta_use),
    bias_HR         = mean(HR_meta_use - HR_true),
    rmse_HR         = sqrt(mean((HR_meta_use - HR_true)^2)),
    mean_tau2       = mean(tau2_meta_use),
    bias_tau2       = mean(tau2_meta_use - tau2_logHR),
    rmse_tau2       = sqrt(mean((tau2_meta_use - tau2_logHR)^2)),
    mean_I2         = mean(I2_meta_use)
  )

  list(
    settings = list(
      n_rep           = n_rep,
      K               = K,
      dist            = dist,
      baseline_params = baseline_params,
      mu_logHR        = mu_logHR,
      tau2_logHR      = tau2_logHR,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual,
      meta_method     = meta_method
    ),
    meta_paths = list(
      logHR_meta = logHR_meta_vec,
      HR_meta    = HR_meta_vec,
      tau2_meta  = tau2_meta_vec,
      I2_meta    = I2_meta_vec
    ),
    summary = summary_list
  )
}

