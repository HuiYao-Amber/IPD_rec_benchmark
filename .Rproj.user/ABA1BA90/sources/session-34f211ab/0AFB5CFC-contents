## ---- 3. Two-stage random-effects meta-analysis ----

meta_analyze_two_stage <- function(
    logHR_vec,
    se_vec,
    method = "REML"
) {
  logHR_vec <- as.numeric(logHR_vec)
  se_vec    <- as.numeric(se_vec)

  if (length(logHR_vec) != length(se_vec)) {
    stop("logHR_vec and se_vec must have the same length.")
  }

  # 过滤掉 NA 或 不合理的 se
  idx <- which(is.finite(logHR_vec) & is.finite(se_vec) & se_vec > 0)
  if (length(idx) < 2L) {
    warning("Less than 2 valid trials for meta-analysis; returning NA.")
    return(list(
      logHR_meta = NA_real_,
      se_meta    = NA_real_,
      HR_meta    = NA_real_,
      ci_lower   = NA_real_,
      ci_upper   = NA_real_,
      tau2       = NA_real_,
      I2         = NA_real_,
      k_eff      = length(idx),
      idx_used   = idx
    ))
  }

  logHR_use <- logHR_vec[idx]
  se_use    <- se_vec[idx]

  # 用 metafor 做随机效应 meta
  res <- metafor::rma(yi = logHR_use, sei = se_use, method = method)

  logHR_meta <- as.numeric(res$b)
  se_meta    <- as.numeric(res$se)
  HR_meta    <- exp(logHR_meta)

  ci_log <- c(res$ci.lb, res$ci.ub)
  ci_HR  <- exp(ci_log)

  list(
    logHR_meta = logHR_meta,
    se_meta    = se_meta,
    HR_meta    = HR_meta,
    ci_lower   = ci_HR[1],
    ci_upper   = ci_HR[2],
    tau2       = as.numeric(res$tau2),
    I2         = as.numeric(res$I2),
    k_eff      = length(idx),
    idx_used   = idx
  )
}

