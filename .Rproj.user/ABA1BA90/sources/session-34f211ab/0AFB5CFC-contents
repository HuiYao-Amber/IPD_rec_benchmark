# 方法 1：IPDfromKM
reconstruct_fun_ipdfromkm <- function(ipd_true, trial_id, sd_S = 0.01, ...) {
  reconstruct_stub(ipd_true, trial_id, method = "ipdfromkm", sd_S = sd_S)
}

# 方法 2：kmdata (Guyot)
reconstruct_fun_kmdata_guyot <- function(ipd_true, trial_id, sd_S = 0.01, ...) {
  reconstruct_stub(ipd_true, trial_id, method = "kmdata_guyot", sd_S = sd_S)
}

# 方法 3：KMtoIPD (Rogula)
reconstruct_fun_kmtoipd_rogula <- function(ipd_true, trial_id, sd_S = 0.01, ...) {
  reconstruct_stub(ipd_true, trial_id, method = "kmtoipd_rogula", sd_S = sd_S)
}


