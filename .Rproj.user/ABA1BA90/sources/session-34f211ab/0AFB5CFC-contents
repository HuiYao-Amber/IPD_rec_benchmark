## ---- 2. Estimate HR in a single trial via Cox ----

estimate_trial_hr <- function(ipd) {
  ipd <- as.data.frame(ipd)

  # 基本检查
  if (!all(c("arm", "time", "status") %in% names(ipd))) {
    stop("IPD must contain columns: arm, time, status.")
  }
  if (length(unique(ipd$arm)) < 2L) {
    warning("Only one treatment arm present; returning NA HR.")
    return(list(
      logHR_hat = NA_real_,
      se_logHR  = NA_real_,
      HR_hat    = NA_real_,
      ci_lower  = NA_real_,
      ci_upper  = NA_real_
    ))
  }
  if (sum(ipd$status) == 0L) {
    warning("No events in this trial; returning NA HR.")
    return(list(
      logHR_hat = NA_real_,
      se_logHR  = NA_real_,
      HR_hat    = NA_real_,
      ci_lower  = NA_real_,
      ci_upper  = NA_real_
    ))
  }

  # Cox 回归：Treat vs Control
  fit <- survival::coxph(Surv(time, status) ~ arm, data = ipd)

  cf <- stats::coef(fit)
  vc <- stats::vcov(fit)

  if (length(cf) == 0L || any(!is.finite(cf))) {
    warning("coxph returned no finite coefficients; returning NA HR.")
    return(list(
      logHR_hat = NA_real_,
      se_logHR  = NA_real_,
      HR_hat    = NA_real_,
      ci_lower  = NA_real_,
      ci_upper  = NA_real_
    ))
  }

  # 这里不按名字取，直接取第一个系数
  logHR <- as.numeric(cf[1])
  se    <- sqrt(as.numeric(vc[1, 1]))

  HR_hat <- exp(logHR)
  ci_log <- logHR + c(-1, 1) * 1.96 * se
  ci_HR  <- exp(ci_log)

  list(
    logHR_hat = logHR,
    se_logHR  = se,
    HR_hat    = HR_hat,
    ci_lower  = ci_HR[1],
    ci_upper  = ci_HR[2]
  )
}

