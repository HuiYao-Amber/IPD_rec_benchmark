## ---- 9. Scenario grid + driver ----
## 依赖:
##   - data.table
##   - simulate_meta_replicate_multi_methods() （Block 8）


###  9.1 构造 meta-analysis 的 scenario grid ----
## 输入是一堆“取值向量”，函数帮你做笛卡尔积，并附上 scenario_id
##
## 说明:
##   - dist 固定成 "weibull"（如果将来要多分布，可以自己拓展）
##   - baseline_shape, baseline_scale: 控制组 Weibull 参数
##   - mu_HR_vec: 真 pooled HR（>0），内部自动 log() 变成 mu_logHR
##   - tau2_vec : 真 between-trial 方差 (logHR 空间)
##   - K_vec    : trial 数
##   - n_control_vec, n_treat_vec: 每 trial 两组样本量
##   - censor_vec: 目标删失率
##   - accrual_vec: 入组窗口长度
##   - sd_S_vec: digitize 噪声（生存概率上的 sd）
##
## 输出:
##   data.table，每一行一个 scenario，带 scenario_id 字段

make_meta_scenario_grid <- function(
    baseline_shape  = 1.2,
    baseline_scale  = 10,
    mu_HR_vec       = c(0.6, 0.75, 0.9),
    tau2_vec        = c(0, 0.02, 0.05),
    K_vec           = c(3, 5, 10),
    n_control_vec   = c(100),
    n_treat_vec     = c(100),
    censor_vec      = c(0.2, 0.4),
    accrual_vec     = c(0),
    sd_S_vec        = c(0.01)
) {
  dt <- CJ(
    baseline_shape = baseline_shape,
    baseline_scale = baseline_scale,
    mu_HR          = mu_HR_vec,
    tau2_logHR     = tau2_vec,
    K              = K_vec,
    n_control      = n_control_vec,
    n_treatment    = n_treat_vec,
    target_censoring = censor_vec,
    accrual        = accrual_vec,
    sd_S           = sd_S_vec
  )

  # 真 HR -> logHR
  dt[, mu_logHR := log(mu_HR)]

  # 场景编号
  dt[, scenario_id := .I]

  # baseline_params 之后会按行拼成 list 用
  dt[]
}



### 9.2 对 scenario_grid 的一行进行仿真 ---------------------------
##   - idx: 第几行 scenario
##   - scenario_grid: 由 make_meta_scenario_grid() 生成的 data.table
##   - n_rep: 这个 scenario 下跑多少个 replicate
##   - methods: 要比较的重建方法 (字符向量)
##   - meta_method: metafor 的方法 ("REML", "DL", ...)
##   - seed_base: 总体种子，用来生成每个 scenario 的子 seed
##
## 输出:
##   data.table (长格式)，每行 = 某个 method 在该 scenario 下的 summary:
##     scenario_id, 所有 scenario 参数, method, 各种指标

run_meta_scenario_row <- function(
    idx,
    scenario_grid,
    n_rep,
    methods = c("ipdfromkm", "kmdata_guyot", "kmtoipd_rogula"),
    meta_method = "REML",
    seed_base = 2026
) {
  sg <- as.data.table(scenario_grid)
  if (idx < 1L || idx > nrow(sg)) {
    stop("idx out of range.")
  }

  scen <- sg[idx]

  # 为这个 scenario 构造一个 seed_scen，保证不同 scenario 之间可复现
  seed_scen <- if (!is.null(seed_base)) seed_base + scen$scenario_id - 1L else NULL

  baseline_params <- list(
    shape = scen$baseline_shape,
    scale = scen$baseline_scale
  )

  # 调用 Block 8 的多方法仿真
  res <- simulate_meta_replicate_multi_methods(
    n_rep          = n_rep,
    methods        = methods,
    K              = scen$K,
    dist           = "weibull",
    baseline_params = baseline_params,
    mu_logHR       = scen$mu_logHR,
    tau2_logHR     = scen$tau2_logHR,
    n_control      = scen$n_control,
    n_treatment    = scen$n_treatment,
    target_censoring = scen$target_censoring,
    accrual        = scen$accrual,
    meta_method    = meta_method,
    sd_S           = scen$sd_S,
    seed           = seed_scen
  )

  # 把 summary_list 按方法展开成长表
  summ_list <- res$summary
  methods_used <- names(summ_list)

  rows <- lapply(methods_used, function(m) {
    s <- summ_list[[m]]
    # 以 data.table 的形式返回一行
    data.table(
      scenario_id      = scen$scenario_id,
      baseline_shape   = scen$baseline_shape,
      baseline_scale   = scen$baseline_scale,
      mu_HR            = scen$mu_HR,
      mu_logHR         = scen$mu_logHR,
      tau2_logHR_true  = scen$tau2_logHR,
      K                = scen$K,
      n_control        = scen$n_control,
      n_treatment      = scen$n_treatment,
      target_censoring = scen$target_censoring,
      accrual          = scen$accrual,
      sd_S             = scen$sd_S,
      meta_method      = meta_method,
      method           = s$method,
      n_valid          = s$n_valid,
      # HR 层面对真值的表现（true / recon）
      mean_HR_true     = s$mean_HR_true,
      bias_HR_true     = s$bias_HR_true,
      rmse_HR_true     = s$rmse_HR_true,
      mean_HR_recon    = s$mean_HR_recon,
      bias_HR_recon    = s$bias_HR_recon,
      rmse_HR_recon    = s$rmse_HR_recon,
      mean_delta_HR    = s$mean_delta_HR,
      rmse_delta_HR    = s$rmse_delta_HR,
      # tau2 / I2 的平均
      mean_tau2_true   = s$mean_tau2_true,
      mean_tau2_recon  = s$mean_tau2_recon,
      mean_I2_true     = s$mean_I2_true,
      mean_I2_recon    = s$mean_I2_recon
    )
  })

  rbindlist(rows, use.names = TRUE)
}


### 9.3 对整个 scenario_grid 批量仿真 ------------------------------
##   - scenario_grid: make_meta_scenario_grid() 的输出
##   - n_rep: 每个 scenario 的 replicate 次数
##   - methods, meta_method, seed_base: 同上
##
## 输出:
##   data.table: 每一行 = (scenario_id, method) 的 summary，
##   可以直接 ggplot 或导出为 csv/表格。

run_meta_scenarios_batch <- function(
    scenario_grid,
    n_rep,
    methods = c("ipdfromkm", "kmdata_guyot", "kmtoipd_rogula"),
    meta_method = "REML",
    seed_base = 2026,
    verbose = TRUE
) {
  sg <- as.data.table(scenario_grid)
  n_scen <- nrow(sg)
  if (n_scen < 1L) stop("scenario_grid has no rows.")

  res_list <- vector("list", length = n_scen)

  for (i in seq_len(n_scen)) {
    if (verbose) {
      message("Running scenario ", i, "/", n_scen,
              " (scenario_id = ", sg$scenario_id[i], ") ...")
    }

    res_i <- run_meta_scenario_row(
      idx           = i,
      scenario_grid = sg,
      n_rep         = n_rep,
      methods       = methods,
      meta_method   = meta_method,
      seed_base     = seed_base
    )

    res_list[[i]] <- res_i
  }

  out <- rbindlist(res_list, use.names = TRUE)
  out[]
}


