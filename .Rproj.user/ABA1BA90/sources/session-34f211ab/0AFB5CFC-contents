## =========================================================
## 一次 replicate：同时算 T / A / Rm / Hm
## =========================================================

simulate_meta_one_rep_missing <- function(
    K,
    dist = c("weibull"),
    baseline_params,
    mu_logHR,
    tau2_logHR,
    n_control,
    n_treatment,
    target_censoring = 0.25,
    accrual          = 0,
    methods          = c("ipdfromkm","kmdata_guyot","kmtoipd_rogula"),
    p_miss_HR        = 0,
    sd_S             = 0.01,
    meta_method      = "REML",
    seed             = NULL
) {
  dist    <- match.arg(dist)
  methods <- as.character(methods)

  stopifnot(K >= 2)
  stopifnot(tau2_logHR >= 0)
  stopifnot(p_miss_HR >= 0, p_miss_HR <= 1)

  if (!is.null(seed)) set.seed(seed)

  shape <- baseline_params$shape
  scale_ctrl <- baseline_params$scale

  ## --------- 1. 生成 true IPD + per-trial AD logHR / SE ---------
  ipd_true_list     <- vector("list", K)

  logHR_true        <- numeric(K)
  HR_true           <- numeric(K)

  logHR_hat_true    <- rep(NA_real_, K)
  HR_hat_true       <- rep(NA_real_, K)
  se_logHR_true     <- rep(NA_real_, K)

  for (j in seq_len(K)) {
    # trial-level true logHR_j
    logHR_j <- if (tau2_logHR > 0) {
      stats::rnorm(1, mean = mu_logHR, sd = sqrt(tau2_logHR))
    } else {
      mu_logHR
    }
    HR_j <- exp(logHR_j)

    logHR_true[j] <- logHR_j
    HR_true[j]    <- HR_j

    # treatment scale 根据 HR_j 调整（Weibull）
    scale_trt <- scale_ctrl * HR_j^(-1 / shape)

    ipd_true_j <- simulate_trial_twoarm_param(
      trial_id        = j,
      dist            = dist,
      control_params  = list(shape = shape, scale = scale_ctrl),
      treat_params    = list(shape = shape, scale = scale_trt),
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual
    )

    ipd_true_list[[j]] <- ipd_true_j

    est_true_j <- estimate_trial_hr(ipd_true_j)

    logHR_hat_true[j] <- est_true_j$logHR_hat
    HR_hat_true[j]    <- est_true_j$HR_hat
    se_logHR_true[j]  <- est_true_j$se_logHR
  }

  valid_ad <- is.finite(logHR_hat_true) & is.finite(se_logHR_true) & se_logHR_true > 0

  ## --------- 2. 随机指定哪些 trial 报告 HR（missing HR 机制） ---------
  has_HR <- rep(FALSE, K)
  if (any(valid_ad)) {
    if (p_miss_HR <= 0) {
      has_HR[valid_ad] <- TRUE
    } else if (p_miss_HR >= 1) {
      has_HR[valid_ad] <- FALSE
    } else {
      idx <- which(valid_ad)
      miss_flag <- stats::rbinom(length(idx), size = 1, prob = p_miss_HR)  # 1 = missing
      has_HR[idx] <- (miss_flag == 0L)
    }
  }

  ## --------- 3. True meta: T（用所有 valid trial 的 AD HR） ----------
  meta_T <- meta_analyze_two_stage(
    logHR_vec = logHR_hat_true,
    se_vec    = se_logHR_true,
    method    = meta_method
  )

  ## --------- 4. AD-only meta: A（只用未 missing 的 HR） ----------
  logHR_AD <- logHR_hat_true
  se_AD    <- se_logHR_true
  logHR_AD[!has_HR] <- NA_real_
  se_AD[!has_HR]    <- NA_real_

  meta_A <- meta_analyze_two_stage(
    logHR_vec = logHR_AD,
    se_vec    = se_AD,
    method    = meta_method
  )

  ## --------- 5. Reconstruction for each method m ----------
  n_m <- length(methods)
  logHR_hat_recon_mat <- matrix(NA_real_, nrow = n_m, ncol = K,
                                dimnames = list(methods, paste0("trial", seq_len(K))))
  se_logHR_recon_mat  <- matrix(NA_real_, nrow = n_m, ncol = K,
                                dimnames = list(methods, paste0("trial", seq_len(K))))

  get_reconstruct_fun <- function(method) {
    if (method == "ipdfromkm")      return(reconstruct_fun_ipdfromkm)
    if (method == "kmdata_guyot")   return(reconstruct_fun_kmdata_guyot)
    if (method == "kmtoipd_rogula") return(reconstruct_fun_kmtoipd_rogula)
    stop("Unknown reconstruct method: ", method)
  }

  for (m_idx in seq_len(n_m)) {
    m_name <- methods[m_idx]
    recon_fun_m <- get_reconstruct_fun(m_name)

    for (j in seq_len(K)) {
      ipd_true_j <- ipd_true_list[[j]]

      ipd_recon_j <- recon_fun_m(
        ipd_true = ipd_true_j,
        trial_id = j,
        sd_S     = sd_S
      )

      ipd_recon_j <- as.data.frame(ipd_recon_j)
      if (!all(c("arm","time","status") %in% names(ipd_recon_j))) next

      # 保证 arm 是 0/1（与 estimate_trial_hr 约定一致）
      if (is.character(ipd_recon_j$arm) || is.factor(ipd_recon_j$arm)) {
        ipd_recon_j$arm <- ifelse(ipd_recon_j$arm == "Treatment", 1L, 0L)
      } else {
        ipd_recon_j$arm <- as.integer(ipd_recon_j$arm)
      }
      if (!"trial_id" %in% names(ipd_recon_j)) {
        ipd_recon_j$trial_id <- j
      }

      est_recon_j <- estimate_trial_hr(ipd_recon_j)

      logHR_hat_recon_mat[m_idx, j] <- est_recon_j$logHR_hat
      se_logHR_recon_mat[m_idx, j]  <- est_recon_j$se_logHR
    }
  }

  ## --------- 6. Meta for Rm & Hm ----------
  rows <- list()
  add_row <- function(method, analysis, meta_res) {
    rows[[length(rows) + 1L]] <<- data.table::data.table(
      method     = method,
      analysis   = analysis,
      logHR_meta = meta_res$logHR_meta,
      se_meta    = meta_res$se_meta,
      HR_meta    = meta_res$HR_meta,
      ci_lower   = meta_res$ci_lower,
      ci_upper   = meta_res$ci_upper,
      tau2_meta  = meta_res$tau2,
      I2_meta    = meta_res$I2,
      k_eff      = meta_res$k_eff
    )
  }

  add_row("truth",   "T", meta_T)
  add_row("AD_only", "A", meta_A)

  for (m_idx in seq_len(n_m)) {
    m_name <- methods[m_idx]
    logHR_recon <- logHR_hat_recon_mat[m_idx, ]
    se_recon    <- se_logHR_recon_mat[m_idx, ]

    # Rm: reconstructed-only meta
    meta_Rm <- meta_analyze_two_stage(
      logHR_vec = logHR_recon,
      se_vec    = se_recon,
      method    = meta_method
    )
    add_row(m_name, "Rm", meta_Rm)

    # Hm: hybrid meta (优先用真实 AD HR，有缺失才用重建)
    logHR_hyb <- logHR_recon
    se_hyb    <- se_recon

    idx_ad <- which(has_HR & valid_ad)
    if (length(idx_ad) > 0L) {
      logHR_hyb[idx_ad] <- logHR_hat_true[idx_ad]
      se_hyb[idx_ad]    <- se_logHR_true[idx_ad]
    }

    meta_Hm <- meta_analyze_two_stage(
      logHR_vec = logHR_hyb,
      se_vec    = se_hyb,
      method    = meta_method
    )
    add_row(m_name, "Hm", meta_Hm)
  }

  meta_dt <- data.table::rbindlist(rows, use.names = TRUE, fill = TRUE)

  list(
    settings = list(
      K               = K,
      dist            = dist,
      baseline_params = baseline_params,
      mu_logHR        = mu_logHR,
      tau2_logHR      = tau2_logHR,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual,
      meta_method     = meta_method,
      p_miss_HR       = p_miss_HR,
      methods         = methods,
      sd_S            = sd_S
    ),
    trial_level = list(
      logHR_true      = logHR_true,
      HR_true         = HR_true,
      logHR_hat_true  = logHR_hat_true,
      HR_hat_true     = HR_hat_true,
      se_logHR_true   = se_logHR_true,
      has_HR          = has_HR
    ),
    meta = meta_dt
  )
}





## =========================================================
## 多个 replicate：固定一个 scenario，循环 R 次
## =========================================================

simulate_meta_replicate_missing <- function(
    n_rep,
    methods,
    scenario_id,
    block,
    K,
    dist = c("weibull"),
    baseline_params,
    mu_logHR,
    tau2_logHR,
    n_control,
    n_treatment,
    target_censoring,
    accrual,
    p_miss_HR,
    sd_S,
    meta_method = "REML",
    seed = NULL
) {
  dist    <- match.arg(dist)
  methods <- as.character(methods)

  stopifnot(n_rep >= 1)
  if (!is.null(seed)) set.seed(seed)

  mu_HR <- exp(mu_logHR)

  meta_long <- data.table::data.table()

  for (r in seq_len(n_rep)) {
    seed_r <- if (!is.null(seed)) seed + r - 1L else NULL

    one <- simulate_meta_one_rep_missing(
      K               = K,
      dist            = dist,
      baseline_params = baseline_params,
      mu_logHR        = mu_logHR,
      tau2_logHR      = tau2_logHR,
      n_control       = n_control,
      n_treatment     = n_treatment,
      target_censoring = target_censoring,
      accrual         = accrual,
      methods         = methods,
      p_miss_HR       = p_miss_HR,
      sd_S            = sd_S,
      meta_method     = meta_method,
      seed            = seed_r
    )

    dt_r <- one$meta
    dt_r[, rep_id := r]

    meta_long <- data.table::rbindlist(
      list(meta_long, dt_r),
      use.names = TRUE, fill = TRUE
    )
  }

  ## 把每个 replicate 的 T 结果拿出来作为 “参考真值”（simulation 级的基准）
  truth_dt <- meta_long[
    method == "truth" & analysis == "T",
    .(rep_id, HR_T = HR_meta, logHR_T = logHR_meta,
      tau2_T = tau2_meta, I2_T = I2_meta)
  ]

  meta_long <- merge(
    meta_long,
    truth_dt,
    by = "rep_id",
    all.x = TRUE,
    sort = FALSE
  )

  mu_HR_scalar <- mu_HR
  tau2_true    <- tau2_logHR

  meta_long[, `:=`(
    diff_HR_mu = HR_meta - mu_HR_scalar,
    diff_HR_T  = HR_meta - HR_T,
    diff_tau2  = tau2_meta - tau2_true,
    coverage_mu = as.numeric(
      is.finite(ci_lower) & is.finite(ci_upper) &
        ci_lower <= mu_HR_scalar & ci_upper >= mu_HR_scalar
    ),
    coverage_T = as.numeric(
      is.finite(ci_lower) & is.finite(ci_upper) &
        is.finite(HR_T) & ci_lower <= HR_T & ci_upper >= HR_T
    )
  )]

  ## ---- summary by (method, analysis) ----
  summary_dt <- meta_long[
    is.finite(HR_meta) & is.finite(HR_T),
    .(
      n_valid         = .N,
      mean_HR_est     = mean(HR_meta, na.rm = TRUE),
      bias_HR_mu      = mean(diff_HR_mu, na.rm = TRUE),
      rmse_HR_mu      = sqrt(mean(diff_HR_mu^2, na.rm = TRUE)),
      mean_delta_HR_T = mean(diff_HR_T, na.rm = TRUE),
      rmse_delta_HR_T = sqrt(mean(diff_HR_T^2, na.rm = TRUE)),
      mean_tau2_meta  = mean(tau2_meta, na.rm = TRUE),
      bias_tau2       = mean(diff_tau2, na.rm = TRUE),
      mean_I2_meta    = mean(I2_meta, na.rm = TRUE),
      coverage_mu     = mean(coverage_mu, na.rm = TRUE),
      coverage_T      = mean(coverage_T, na.rm = TRUE)
    ),
    by = .(method, analysis)
  ]

  ## 把 scenario 信息加上
  summary_dt[, `:=`(
    scenario_id      = scenario_id,
    block            = block,
    K                = K,
    n_control        = n_control,
    n_treatment      = n_treatment,
    baseline_shape   = baseline_params$shape,
    baseline_scale   = baseline_params$scale,
    mu_HR            = mu_HR_scalar,
    mu_logHR         = mu_logHR,
    tau2_logHR_true  = tau2_true,
    target_censoring = target_censoring,
    accrual          = accrual,
    p_miss_HR        = p_miss_HR,
    sd_S             = sd_S,
    meta_method      = meta_method
  )]

  data.table::setcolorder(
    summary_dt,
    c("scenario_id", "block", "method", "analysis",
      "K", "n_control", "n_treatment",
      "baseline_shape", "baseline_scale",
      "mu_HR", "mu_logHR", "tau2_logHR_true",
      "target_censoring", "accrual",
      "p_miss_HR", "sd_S", "meta_method",
      "n_valid",
      "mean_HR_est", "bias_HR_mu", "rmse_HR_mu",
      "mean_delta_HR_T", "rmse_delta_HR_T",
      "mean_tau2_meta", "bias_tau2", "mean_I2_meta",
      "coverage_mu", "coverage_T")
  )

  list(
    meta_long = meta_long,
    summary   = summary_dt
  )
}





## =========================================================
## Phase 3 主入口：按 Block A–D 跑完所有场景
## =========================================================

run_meta_phase3_benchmark <- function(
    n_rep_per_scenario = 200,
    methods            = c("ipdfromkm","kmdata_guyot","kmtoipd_rogula"),
    meta_method        = "REML",
    mu_HR              = 0.75,
    baseline_shape     = 1.2,
    baseline_scale     = 10,
    seed_base          = 2026,
    out_file           = "meta_phase3_benchmark.csv",
    verbose            = TRUE
) {
  stopifnot(requireNamespace("data.table", quietly = TRUE))
  library(data.table)

  scen_grid <- make_meta_scenario_grid_phase3(
    mu_HR          = mu_HR,
    baseline_shape = baseline_shape,
    baseline_scale = baseline_scale
  )

  if (verbose) {
    message("Phase 3: total scenarios = ", nrow(scen_grid))
  }

  res_list <- vector("list", nrow(scen_grid))

  for (i in seq_len(nrow(scen_grid))) {
    sc <- scen_grid[i]

    if (verbose) {
      message(sprintf(
        "[Phase3] Scenario %d/%d: block=%s, K=%d, n=%d, p_miss=%.2f, tau2=%.3f, censor=%.2f, sd_S=%.2f",
        sc$scenario_id, nrow(scen_grid),
        sc$block, sc$K, sc$n_control,
        sc$p_miss_HR, sc$tau2_logHR_true,
        sc$target_censoring, sc$sd_S
      ))
    }

    baseline_params <- list(
      shape = sc$baseline_shape,
      scale = sc$baseline_scale
    )

    seed_i <- if (!is.null(seed_base)) seed_base + i - 1L else NULL

    res_i <- simulate_meta_replicate_missing(
      n_rep          = n_rep_per_scenario,
      methods        = methods,
      scenario_id    = sc$scenario_id,
      block          = sc$block,
      K              = sc$K,
      dist           = "weibull",
      baseline_params = baseline_params,
      mu_logHR       = sc$mu_logHR,
      tau2_logHR     = sc$tau2_logHR_true,
      n_control      = sc$n_control,
      n_treatment    = sc$n_treatment,
      target_censoring = sc$target_censoring,
      accrual        = sc$accrual,
      p_miss_HR      = sc$p_miss_HR,
      sd_S           = sc$sd_S,
      meta_method    = meta_method,
      seed           = seed_i
    )

    # 把 scenario 表里的一些标签（size_label）补充进 summary
    summary_i <- res_i$summary
    if ("size_label" %in% names(sc)) {
      summary_i[, size_label := sc$size_label]
    } else {
      summary_i[, size_label := NA_character_]
    }

    res_list[[i]] <- summary_i
  }

  res_phase3 <- rbindlist(res_list, use.names = TRUE, fill = TRUE)

  data.table::fwrite(res_phase3, out_file)

  if (verbose) {
    message("Phase 3 meta benchmark finished. Results saved to: ",
            normalizePath(out_file, winslash = "/"))
  }

  list(
    scenario_grid = scen_grid,
    results       = res_phase3
  )
}



