## ---- 7. 三种 IPD 重建方法 + 加噪声 digitize + reconstruct_stub ----
## 依赖:
##   - data.table
##   - survival
##   - IPDfromKM
##   - kmdata
##   - KMtoIPD
##   - 已定义好的 simulate_meta_one_rep_recon()


### ---------- 7.1 用真 IPD 生成 “带噪声的 KM 曲线” ----------
## 思路：
##   1) 对每个 arm 单独 survfit()
##   2) 拿到 (time, S) 序列
##   3) 在 S 上加 N(0, sd_S^2) 噪声
##   4) 截断到 [0,1]，再用 cummin 保证单调不升
##
## 输出 digi_dt: time, St, curve
##   curve = 1 表 Control, 2 表 Treatment

digitize_km_from_true_ipd_noise <- function(
    ipd_true,
    sd_S = 0.01   # 生存概率上的噪声标准差，0.01 ~ 0.02 一般比较温和
) {
  ipd_true <- as.data.table(ipd_true)
  stopifnot(all(c("arm", "time", "status") %in% names(ipd_true)))

  ipd_true[, arm := as.integer(arm)]

  make_curve <- function(dat_arm, curve_id) {
    if (nrow(dat_arm) == 0) {
      stop("No data for arm = ", curve_id)
    }
    sfit <- survfit(Surv(time, status) ~ 1, data = dat_arm)
    sm   <- summary(sfit)
    times <- c(0, sm$time)
    S     <- c(1, sm$surv)

    if (sd_S > 0) {
      eps <- rnorm(length(S), mean = 0, sd = sd_S)
      S_noisy <- S + eps
      S_noisy <- pmax(pmin(S_noisy, 1), 0)  # 截断到 [0,1]
      # 保证随时间单调不升
      S_noisy <- cummin(S_noisy)
      # 起点强制是 1
      S_noisy[1] <- 1
    } else {
      S_noisy <- S
    }

    data.table(
      time  = times,
      St    = S_noisy,
      curve = as.integer(curve_id)
    )
  }

  dt_ctrl <- make_curve(ipd_true[arm == 0], curve_id = 1L)
  dt_trt  <- make_curve(ipd_true[arm == 1], curve_id = 2L)

  digi_dt <- rbind(dt_ctrl, dt_trt)
  digi_dt <- digi_dt[is.finite(time) & is.finite(St)]
  digi_dt[, St := pmax(pmin(St, 1), 0)]
  digi_dt[]
}

### ---------- 7.2 risk table：用真 IPD 构造 at-risk 表 ----------
## 默认把时间分成 n_break 段；meta 场景里不需要太精细

build_risk_table_from_ipd <- function(ipd_true, n_break = 8) {
  ipd_true <- as.data.table(ipd_true)
  stopifnot(all(c("arm", "time", "status") %in% names(ipd_true)))
  ipd_true[, arm := as.integer(arm)]

  x_end <- max(ipd_true$time, na.rm = TRUE)

  x_increment <- round(x_end / n_break)
  if (!is.finite(x_increment) || x_increment <= 0) x_increment <- max(1, x_end)

  times_rt <- seq(0, x_end, by = x_increment)
  if (tail(times_rt, 1) < x_end) {
    times_rt <- c(times_rt, x_end)
  }

  risk_table <- data.table(
    time          = times_rt,
    nrisk_control = vapply(
      times_rt,
      function(t) sum(ipd_true$arm == 0 & ipd_true$time >= t),
      FUN.VALUE = integer(1)
    ),
    nrisk_treat = vapply(
      times_rt,
      function(t) sum(ipd_true$arm == 1 & ipd_true$time >= t),
      FUN.VALUE = integer(1)
    )
  )
  risk_table[]
}

### ---------- 7.3 curve -> arm 映射 (参考你给的 guess_map_by_height / assign_arm_to_curves) ----------

guess_map_by_height <- function(digi_dt, x_end, early_ratio = 1/3) {
  digi_dt <- as.data.table(digi_dt)
  cut <- x_end * early_ratio
  m <- digi_dt[time <= cut, .(m = mean(St, na.rm = TRUE)), by = curve][order(-m)]
  if (nrow(m) < 2) return(NULL)
  # 早期生存率更高的认为是 Treatment，另一个 Control
  setNames(c("Treatment", "Control"), as.character(m$curve[1:2]))
}

assign_arm_to_curves <- function(digi_dt, curve_to_arm = NULL) {
  digi_dt <- as.data.table(digi_dt)
  curves <- sort(unique(as.character(digi_dt$curve)))
  if (length(curves) < 2) stop("Need >=2 curves in digi_dt.")
  curves <- curves[1:2]

  x_end <- max(digi_dt$time, na.rm = TRUE)
  if (is.null(curve_to_arm)) {
    curve_to_arm <- guess_map_by_height(digi_dt, x_end = x_end)
  }

  map_arm <- function(curve_id) {
    if (!is.null(curve_to_arm) && curve_id %in% names(curve_to_arm)) {
      as.character(curve_to_arm[[curve_id]])
    } else {
      if (curve_id == curves[1]) "Control" else "Treatment"
    }
  }
  list(curves = curves, map_arm = map_arm, curve_to_arm = curve_to_arm)
}


### ----7.4 Method 1: IPDfromKM ----

reconstruct_ipd_ipdfromkm <- function(
    digi_dt,
    risk_table,
    totals = NULL,
    curve_to_arm = NULL,
    maxy = 1
) {
  stopifnot(requireNamespace("IPDfromKM", quietly = TRUE))
  digi_dt    <- as.data.table(digi_dt)
  risk_table <- as.data.table(risk_table)

  mp     <- assign_arm_to_curves(digi_dt, curve_to_arm)
  curves <- mp$curves

  one_arm <- function(curve_id) {
    arm <- mp$map_arm(curve_id)

    d <- digi_dt[curve == curve_id, .(time, St)][order(time)]
    nrisk <- if (arm == "Control") risk_table$nrisk_control else risk_table$nrisk_treat
    trisk <- risk_table$time

    totalpts0 <- nrisk[which.min(trisk)]
    if (!is.finite(totalpts0) || totalpts0 <= 0) stop("Invalid baseline nrisk for ", arm)

    # 不再传 NA 给 tot.events
    tot_events <- NULL
    if (!is.null(totals)) {
      te <- if (arm == "Control") totals$total_events_ctrl else totals$total_events_trt
      if (is.finite(te) && te > 0) tot_events <- as.integer(te)
    }

    pre <- IPDfromKM::preprocess(
      dat      = as.data.frame(d),
      trisk    = trisk,
      nrisk    = nrisk,
      totalpts = totalpts0,
      maxy     = maxy
    )

    args <- list(pre)
    if (!is.null(tot_events)) {
      args$tot.events <- tot_events
    }

    obj <- tryCatch(
      do.call(IPDfromKM::getIPD, args),
      error = function(e) {
        warning("IPDfromKM::getIPD failed for arm = ", arm,
                " message: ", conditionMessage(e),
                " -> returning empty.")
        return(NA)
      }
    )

    if (is.na(obj)[1]) {
      return(data.table(time = numeric(0), status = integer(0), arm = character(0)))
    }

    ipd <- if (is.list(obj) && !is.null(obj$IPD)) obj$IPD else obj
    ipd <- as.data.table(ipd)
    setnames(ipd, tolower(names(ipd)))
    ipd[, arm := arm]
    ipd[, .(time, status, arm)]
  }

  ipd_all <- rbindlist(lapply(curves, one_arm), use.names = TRUE)
  list(ipd = ipd_all, meta = list(method = "ipdfromkm", curve_to_arm = mp$curve_to_arm))
}


### ---- 7.5 Method 2: kmdata::ipd (Guyot 2012 实现) ----


reconstruct_ipd_kmdata_guyot <- function(
    digi_dt,
    risk_table,
    totals = NULL,
    curve_to_arm = NULL
) {
  stopifnot(requireNamespace("kmdata", quietly = TRUE))
  digi_dt    <- as.data.table(digi_dt)
  risk_table <- as.data.table(risk_table)

  mp     <- assign_arm_to_curves(digi_dt, curve_to_arm)
  curves <- mp$curves

  one_arm <- function(curve_id) {
    arm <- mp$map_arm(curve_id)
    d <- digi_dt[curve == curve_id, .(time, St)][order(time)]

    t.atrisk <- risk_table$time
    n.atrisk <- if (arm == "Control") risk_table$nrisk_control else risk_table$nrisk_treat

    total_events <- NA
    if (!is.null(totals)) {
      total_events <- if (arm == "Control") totals$total_events_ctrl else totals$total_events_trt
    }

    tau_val <- max(c(d$time, t.atrisk), na.rm = TRUE)

    pd <- tryCatch(
      kmdata::ipd(
        time      = d$time,
        prob      = d$St,
        t.atrisk  = t.atrisk,
        n.atrisk  = n.atrisk,
        total     = total_events,
        arm       = arm,
        tau       = tau_val,
        interpolate = FALSE
      ),
      error = function(e) {
        warning("kmdata::ipd failed for arm = ", arm,
                " message: ", conditionMessage(e),
                " -> returning empty.")
        return(NA)
      }
    )

    if (is.na(pd)[1]) {
      return(data.table(time = numeric(0), status = integer(0), arm = character(0)))
    }

    pd <- as.data.table(pd)
    setnames(pd, tolower(names(pd)))
    if (!("time" %in% names(pd)) && "t" %in% names(pd)) setnames(pd, "t", "time")
    if (!("status" %in% names(pd))) {
      if ("event" %in% names(pd)) setnames(pd, "event", "status")
      if ("d" %in% names(pd))     setnames(pd, "d", "status")
    }

    pd[, arm := arm]
    pd[, .(time, status, arm)]
  }

  ipd_all <- rbindlist(lapply(curves, one_arm), use.names = TRUE)
  list(ipd = ipd_all, meta = list(method = "kmdata_guyot", curve_to_arm = mp$curve_to_arm))
}


### ---- 7.6 Method 3: KMtoIPD (Rogula 2022) ----

extract_drop_bottoms <- function(d_arm) {
  d <- as.data.table(d_arm)[order(time)]
  d[, dS := St - shift(St, 1, type = "lag")]
  drops <- d[!is.na(dS) & dS < 0, .(time, St)]
  drops
}

reconstruct_ipd_kmtoipd_rogula <- function(
    digi_dt,
    risk_table,
    censor_marks_by_arm,
    curve_to_arm = NULL
) {
  stopifnot(requireNamespace("KMtoIPD", quietly = TRUE))
  stopifnot(is.list(censor_marks_by_arm))

  digi_dt    <- as.data.table(digi_dt)
  risk_table <- as.data.table(risk_table)

  mp     <- assign_arm_to_curves(digi_dt, curve_to_arm)
  curves <- mp$curves

  one_arm <- function(curve_id) {
    arm <- mp$map_arm(curve_id)
    d <- digi_dt[curve == curve_id, .(time, St)][order(time)]

    drops <- extract_drop_bottoms(d)
    if (nrow(drops) < 1) {
      warning("No drops found for curve ", curve_id, " (arm=", arm, "); returning empty.")
      return(data.table(time = numeric(0), status = integer(0), arm = character(0)))
    }

    n0 <- if (arm == "Control") risk_table$nrisk_control[1] else risk_table$nrisk_treat[1]
    cens_t <- censor_marks_by_arm[[arm]]
    if (is.null(cens_t)) {
      warning("Missing censor mark times for arm: ", arm, "; returning empty.")
      return(data.table(time = numeric(0), status = integer(0), arm = character(0)))
    }

    ipd <- tryCatch(
      KMtoIPD::getIPD(n0, drops$time, drops$St, cens.t = cens_t),
      error = function(e) {
        warning("KMtoIPD::getIPD failed for arm = ", arm,
                " message: ", conditionMessage(e),
                " -> returning empty.")
        return(NA)
      }
    )

    if (is.na(ipd)[1]) {
      return(data.table(time = numeric(0), status = integer(0), arm = character(0)))
    }

    ipd <- as.data.table(ipd)
    if ("t" %in% names(ipd))     setnames(ipd, "t", "time")
    if ("event" %in% names(ipd)) setnames(ipd, "event", "status")

    ipd[, arm := arm]
    ipd[, .(time, status, arm)]
  }

  ipd_all <- rbindlist(lapply(curves, one_arm), use.names = TRUE)
  list(ipd = ipd_all, meta = list(method = "kmtoipd_rogula", curve_to_arm = mp$curve_to_arm))
}


### ---- 7.7 reconstruct_stub: 统一入口 + 三个 wrapper ----

## reconstruct_stub 接口保持之前约定：
##   reconstruct_stub(ipd_true, trial_id, method = ..., sd_S = ...)
## 然后 simulate_meta_one_rep_recon() 里可以传 wrapper：
##   reconstruct_fun_guyot2012 / reconstruct_fun_rogula2022 / reconstruct_fun_synthipd2025
##
## 目前约定:
##   method = "ipdfromkm"       -> reconstruct_ipd_ipdfromkm()
##   method = "kmdata_guyot"    -> reconstruct_ipd_kmdata_guyot()
##   method = "kmtoipd_rogula"  -> reconstruct_ipd_kmtoipd_rogula()

reconstruct_stub <- function(
    ipd_true,
    trial_id,
    method = c("ipdfromkm", "kmdata_guyot", "kmtoipd_rogula"),
    sd_S = 0.01   # digitize 噪声强度
) {
  method <- match.arg(method)
  ipd_true <- as.data.table(ipd_true)
  stopifnot(all(c("arm", "time", "status") %in% names(ipd_true)))
  ipd_true[, arm := as.integer(arm)]

  ## 1) 构造 “带噪声 KM 曲线” 和 risk table
  digi_dt    <- digitize_km_from_true_ipd_noise(ipd_true, sd_S = sd_S)
  risk_table <- build_risk_table_from_ipd(ipd_true)

  totals <- list(
    total_events_ctrl = ipd_true[arm == 0 & status == 1, .N],
    total_events_trt  = ipd_true[arm == 1 & status == 1, .N]
  )

  ## 2) Method-specific reconstruction
  rec <- switch(
    method,
    "ipdfromkm" = reconstruct_ipd_ipdfromkm(
      digi_dt      = digi_dt,
      risk_table   = risk_table,
      totals       = totals,
      curve_to_arm = NULL,
      maxy         = 1
    ),
    "kmdata_guyot" = reconstruct_ipd_kmdata_guyot(
      digi_dt      = digi_dt,
      risk_table   = risk_table,
      totals       = totals,
      curve_to_arm = NULL
    ),
    "kmtoipd_rogula" = {
      # censor mark times 用真 IPD 的删失时间
      censor_marks_by_arm <- list(
        Control   = sort(unique(ipd_true[arm == 0 & status == 0, time])),
        Treatment = sort(unique(ipd_true[arm == 1 & status == 0, time]))
      )
      reconstruct_ipd_kmtoipd_rogula(
        digi_dt             = digi_dt,
        risk_table          = risk_table,
        censor_marks_by_arm = censor_marks_by_arm,
        curve_to_arm        = NULL
      )
    }
  )

  ipd_rec <- as.data.table(rec$ipd)

  if (nrow(ipd_rec) == 0) {
    warning("Reconstruction (", method, ") empty for trial_id = ", trial_id,
            " -> fallback to true IPD.")
    ipd_true[, trial_id := trial_id]
    return(ipd_true[, .(trial_id, arm, time, status)])
  }

  # 标准化 arm -> 0/1
  if (is.character(ipd_rec$arm) || is.factor(ipd_rec$arm)) {
    ipd_rec[, arm := ifelse(arm == "Treatment", 1L, 0L)]
  } else {
    ipd_rec[, arm := as.integer(arm)]
  }
  ipd_rec[, trial_id := trial_id]
  ipd_rec[, .(trial_id, arm, time, status)]
}

