## ---- 1. Simulate a single two-arm trial (true IPD) ----

# Currently: Weibull baseline, constant HR
# Control:    T ~ Weibull(shape, scale_ctrl)
# Treatment:  T ~ Weibull(shape, scale_trt)
# HR = (scale_ctrl / scale_trt)^shape
#
# Censoring: administrative censoring at calendar time tau_cal,
#   chosen to roughly achieve target_censoring.
# Accrual: Uniform(0, accrual) if accrual > 0.

simulate_trial_twoarm_param <- function(
    trial_id,
    dist = c("weibull"),
    control_params,          # list(shape, scale) for Control
    treat_params,            # list(shape, scale) for Treatment
    n_control,
    n_treatment,
    target_censoring = 0.25, # overall censoring proportion (approx)
    accrual = 0,             # 0 = no staggered entry; >0 = Uniform(0, accrual)
    seed = NULL
) {
  dist <- match.arg(dist)

  if (!is.null(seed)) set.seed(seed)

  stopifnot(target_censoring >= 0, target_censoring <= 0.95)
  stopifnot(n_control > 0, n_treatment > 0)

  ## --- 1.1 Simulate event times ---
  if (dist == "weibull") {
    shape_ctrl <- control_params$shape
    scale_ctrl <- control_params$scale
    shape_trt  <- treat_params$shape
    scale_trt  <- treat_params$scale

    stopifnot(shape_ctrl > 0, scale_ctrl > 0,
              shape_trt  > 0, scale_trt  > 0)

    T_ctrl <- stats::rweibull(n_control, shape = shape_ctrl, scale = scale_ctrl)
    T_trt  <- stats::rweibull(n_treatment, shape = shape_trt,  scale = scale_trt)
  } else {
    stop("Currently only dist = 'weibull' is implemented.")
  }

  ## --- 1.2 Accrual (entry times) ---
  if (accrual > 0) {
    entry_ctrl <- stats::runif(n_control, 0, accrual)
    entry_trt  <- stats::runif(n_treatment, 0, accrual)
  } else {
    entry_ctrl <- rep(0, n_control)
    entry_trt  <- rep(0, n_treatment)
  }

  ## --- 1.3 Administrative censoring ---
  # calendar event times
  cal_T_ctrl <- entry_ctrl + T_ctrl
  cal_T_trt  <- entry_trt  + T_trt
  all_cal_T  <- c(cal_T_ctrl, cal_T_trt)

  if (target_censoring > 0) {
    # 把删失 cut 在 (1 - target_censoring) 分位数
    tau_cal <- stats::quantile(all_cal_T, probs = 1 - target_censoring)
    tau_cal <- as.numeric(tau_cal)
  } else {
    tau_cal <- max(all_cal_T) + 1e-8  # 几乎没有删失
  }

  # 每个人的最大随访时间 = tau_cal - entry
  tau_ctrl <- pmax(tau_cal - entry_ctrl, 1e-8)
  tau_trt  <- pmax(tau_cal - entry_trt,  1e-8)

  # 观测到的随访时间 & 结局指示
  time_ctrl   <- pmin(T_ctrl, tau_ctrl)
  status_ctrl <- as.integer(T_ctrl <= tau_ctrl)

  time_trt    <- pmin(T_trt,  tau_trt)
  status_trt  <- as.integer(T_trt  <= tau_trt)

  ## --- 1.4 Assemble IPD ---
  dt_ctrl <- data.table::data.table(
    trial_id = trial_id,
    arm      = 0L,          # 0 = Control
    time     = time_ctrl,
    status   = status_ctrl
  )

  dt_trt <- data.table::data.table(
    trial_id = trial_id,
    arm      = 1L,          # 1 = Treatment
    time     = time_trt,
    status   = status_trt
  )

  ipd <- data.table::rbindlist(list(dt_ctrl, dt_trt))
  data.table::setkey(ipd, trial_id, arm)

  attr(ipd, "tau_calendar") <- tau_cal

  ipd
}

