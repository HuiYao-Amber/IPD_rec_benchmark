# single_trial_simulation_metrics.R
# Minimal evaluation metrics for:
# (1) digitization error
# (2) reconstruction error
#
# Dependencies:
#   survival (required)
#   survRM2  (optional, only for RMST metric)
###############################################################################

# ---- internal helpers ----

.fix_arm_labels <- function(ipd) {
  ipd <- as.data.frame(ipd)
  if (!all(c("time","status","arm") %in% names(ipd))) {
    stop("IPD must have columns: time, status, arm.")
  }
  ipd$arm <- as.character(ipd$arm)
  ipd$arm[ipd$arm %in% c("0","control","Control","C","ctrl")] <- "Control"
  ipd$arm[ipd$arm %in% c("1","treat","Treatment","T","trt")]  <- "Treatment"
  ipd$arm <- factor(ipd$arm, levels = c("Control","Treatment"))
  ipd
}

.km_surv_at_times <- function(ipd_arm, times) {
  # KM survival evaluated at specific times (extend=TRUE)
  if (nrow(ipd_arm) == 0L) return(rep(NA_real_, length(times)))
  fit <- survival::survfit(survival::Surv(time, status) ~ 1, data = ipd_arm)
  if (length(fit$time) == 0L) return(rep(1, length(times)))  # no events -> S(t)=1
  summary(fit, times = times, extend = TRUE)$surv
}

# ---- 1) Digitization RMSE: digitized points vs TRUE KM ----
digitize_rmse_twoarm <- function(true_ipd, digi_dt, tau, curve_map) {
  # true_ipd: data.frame(time,status,arm)
  # digi_dt : data.frame/data.table with columns time, St, curve
  # curve_map: named numeric vector, e.g. c(Control=1, Treatment=2)

  if (!all(c("time","St","curve") %in% names(digi_dt))) {
    stop("digi_dt must have columns: time, St, curve.")
  }
  if (is.null(names(curve_map)) || !all(c("Control","Treatment") %in% names(curve_map))) {
    stop("curve_map must be a named vector like c(Control=1, Treatment=2).")
  }

  true_ipd <- .fix_arm_labels(true_ipd)
  dt <- as.data.frame(digi_dt)

  # keep only valid points within [0, tau]
  dt <- dt[is.finite(dt$time) & is.finite(dt$St) & dt$time >= 0 & dt$time <= tau, , drop = FALSE]
  if (nrow(dt) == 0L) {
    return(list(rmse_control=NA_real_, rmse_treatment=NA_real_, rmse_mean=NA_real_,
                n_points_used=0L))
  }

  # label arm by curve_map
  dt$curve <- as.numeric(as.character(dt$curve))
  dt$arm <- NA_character_
  dt$arm[dt$curve == as.numeric(curve_map["Control"])]   <- "Control"
  dt$arm[dt$curve == as.numeric(curve_map["Treatment"])] <- "Treatment"
  dt <- dt[dt$arm %in% c("Control","Treatment"), , drop = FALSE]

  calc_rmse <- function(arm_name) {
    d_a   <- dt[dt$arm == arm_name, , drop = FALSE]
    ipd_a <- true_ipd[true_ipd$arm == arm_name, , drop = FALSE]
    if (nrow(d_a) < 2L || nrow(ipd_a) < 2L) return(NA_real_)
    s_true <- .km_surv_at_times(ipd_a, d_a$time)
    sqrt(mean((d_a$St - s_true)^2, na.rm = TRUE))
  }

  r_ctrl <- calc_rmse("Control")
  r_trt  <- calc_rmse("Treatment")
  r_mean <- if (all(is.na(c(r_ctrl, r_trt)))) NA_real_ else mean(c(r_ctrl, r_trt), na.rm = TRUE)

  list(
    rmse_control   = r_ctrl,
    rmse_treatment = r_trt,
    rmse_mean      = r_mean,
    n_points_used  = nrow(dt)
  )
}

# ---- 2) KM RMSE: reconstructed-IPD KM vs TRUE KM on a grid ----
km_rmse_twoarm <- function(true_ipd, rec_ipd, tau, grid_n = 300) {
  true_ipd <- .fix_arm_labels(true_ipd)
  rec_ipd  <- .fix_arm_labels(rec_ipd)

  grid <- seq(0, tau, length.out = grid_n)

  rmse_arm <- function(arm_name) {
    S_true <- .km_surv_at_times(true_ipd[true_ipd$arm == arm_name, ], grid)
    S_rec  <- .km_surv_at_times(rec_ipd [rec_ipd$arm  == arm_name, ], grid)
    if (all(is.na(S_true)) || all(is.na(S_rec))) return(NA_real_)
    sqrt(mean((S_true - S_rec)^2, na.rm = TRUE))
  }

  r_ctrl <- rmse_arm("Control")
  r_trt  <- rmse_arm("Treatment")
  r_mean <- if (all(is.na(c(r_ctrl, r_trt)))) NA_real_ else mean(c(r_ctrl, r_trt), na.rm = TRUE)

  list(
    km_rmse_control   = r_ctrl,
    km_rmse_treatment = r_trt,
    km_rmse_mean      = r_mean
  )
}

