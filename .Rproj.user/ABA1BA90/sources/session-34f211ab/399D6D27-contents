# ---- 3) Effect metric: Cox logHR difference (recon - true) ----
cox_logHR_diff <- function(true_ipd, rec_ipd,
                           coarsen_true_time = TRUE,
                           min_events_per_arm = 5L,
                           ties = "efron") {
  true_ipd <- .fix_arm_labels(true_ipd)
  rec_ipd  <- .fix_arm_labels(rec_ipd)

  # Helper: infer a "typical" time step from reconstructed IPD (to mimic digitization grid)
  infer_dt <- function(tt) {
    tt <- tt[is.finite(tt)]
    tt <- sort(unique(tt))
    if (length(tt) < 2) return(NA_real_)
    dd <- diff(tt)
    dd <- dd[dd > 0]
    if (!length(dd)) return(NA_real_)
    stats::median(dd)
  }

  # Quick sanity: need both arms and enough events
  if (anyNA(true_ipd$arm) || anyNA(rec_ipd$arm)) return(NA_real_)

  ev_true <- tapply(true_ipd$status == 1, true_ipd$arm, sum)
  ev_rec  <- tapply(rec_ipd$status == 1,  rec_ipd$arm,  sum)

  if (length(ev_true) < 2 || length(ev_rec) < 2) return(NA_real_)
  if (any(ev_true < min_events_per_arm) || any(ev_rec < min_events_per_arm)) return(NA_real_)

  # Optional: coarsen true time to reconstructed grid to reduce tie-induced artificial differences
  if (isTRUE(coarsen_true_time)) {
    dt <- infer_dt(rec_ipd$time)
    if (is.finite(dt) && dt > 0) {
      true_ipd$time <- round(true_ipd$time / dt) * dt
      # guard against negative due to rounding artifacts (shouldn't happen, but safe)
      true_ipd$time[true_ipd$time < 0] <- 0
    }
  }

  safe_beta <- function(ipd) {
    tryCatch({
      fit <- survival::coxph(survival::Surv(time, status) ~ arm, data = ipd, ties = ties)
      b <- unname(stats::coef(fit)[["armTreatment"]])
      if (!is.finite(b)) return(NA_real_)
      b
    }, error = function(e) NA_real_)
  }

  b_true <- safe_beta(true_ipd)
  b_rec  <- safe_beta(rec_ipd)

  if (!is.finite(b_true) || !is.finite(b_rec)) return(NA_real_)
  b_rec - b_true
}




# ---- 4) Optional effect metric: RMST difference (recon - true) ----
rmst_diff <- function(true_ipd, rec_ipd, tau, eps = 1e-6) {
  if (!requireNamespace("survRM2", quietly = TRUE)) return(NA_real_)
  true_ipd <- .fix_arm_labels(true_ipd)
  rec_ipd  <- .fix_arm_labels(rec_ipd)

  # rmst2 requires tau <= min(max time in each arm)
  max_obs_min_arm <- function(dat) {
    t_ctrl <- max(dat$time[dat$arm == "Control"],   na.rm = TRUE)
    t_trt  <- max(dat$time[dat$arm == "Treatment"], na.rm = TRUE)
    min(t_ctrl, t_trt)
  }
  tau_star <- min(tau, max_obs_min_arm(true_ipd), max_obs_min_arm(rec_ipd))
  if (!is.finite(tau_star) || tau_star <= eps) return(NA_real_)

  safe_rmst2 <- function(dat) {
    tryCatch({
      survRM2::rmst2(
        time   = dat$time,
        status = dat$status,
        arm    = as.integer(dat$arm == "Treatment"),
        tau    = tau_star
      )
    }, error = function(e) NULL)
  }

  d_true <- safe_rmst2(true_ipd)
  d_rec  <- safe_rmst2(rec_ipd)
  if (is.null(d_true) || is.null(d_rec)) return(NA_real_)

  est_true <- as.numeric(d_true$unadjusted.result["RMST (arm=1)-(arm=0)", "Est."])
  est_rec  <- as.numeric(d_rec $unadjusted.result["RMST (arm=1)-(arm=0)", "Est."])
  est_rec - est_true
}

# ---- 5) Optional: risk-table consistency of reconstructed IPD ----
nrisk_deviation <- function(rec_ipd, risk_table) {
  rec_ipd <- .fix_arm_labels(rec_ipd)
  rt <- as.data.frame(risk_table)
  if (!all(c("time","nrisk_control","nrisk_treat") %in% names(rt))) {
    stop("risk_table must have columns: time, nrisk_control, nrisk_treat.")
  }
  times <- rt$time

  nrisk_at <- function(ipd_arm) vapply(times, function(tt) sum(ipd_arm$time >= tt), numeric(1))

  rec_ctrl <- nrisk_at(rec_ipd[rec_ipd$arm == "Control", ])
  rec_trt  <- nrisk_at(rec_ipd[rec_ipd$arm == "Treatment", ])

  d_ctrl <- rec_ctrl - rt$nrisk_control
  d_trt  <- rec_trt  - rt$nrisk_treat

  list(
    nrisk_mae_control    = mean(abs(d_ctrl), na.rm = TRUE),
    nrisk_mae_treatment  = mean(abs(d_trt),  na.rm = TRUE),
    nrisk_maxabs_control = max(abs(d_ctrl),  na.rm = TRUE),
    nrisk_maxabs_treatment = max(abs(d_trt), na.rm = TRUE)
  )
}

# ---- one-shot wrapper ----
evaluate_one_method <- function(true_ipd, digi_dt, rec_ipd, risk_table,
                                tau, curve_map,
                                do_rmst = FALSE, grid_n = 300) {
  out <- list()

  out <- c(out, digitize_rmse_twoarm(true_ipd, digi_dt, tau = tau, curve_map = curve_map))
  out <- c(out, km_rmse_twoarm(true_ipd, rec_ipd, tau = tau, grid_n = grid_n))
  out$cox_logHR_diff <- cox_logHR_diff(true_ipd, rec_ipd)


  if (isTRUE(do_rmst)) {
    out$rmst_diff <- rmst_diff(true_ipd, rec_ipd, tau = tau)
  }

  out <- c(out, nrisk_deviation(rec_ipd, risk_table))

  out
}

